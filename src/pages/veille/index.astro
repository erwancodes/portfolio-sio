---
import Layout from '../../layouts/Layout.astro';
import { articles, formatDate } from '../../data/veille';
---

<Layout title="Veille Technologique - Erwan Sagnardon">
  <section class="pb-12">
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Veille Technologique</h1>
    <p class="mt-2 font-mono text-sm text-muted-foreground">Theme : Robotique Humanoide & World Models</p>
    <p class="mt-6 max-w-2xl leading-relaxed text-muted-foreground">
      Suivi des avancees en robotique humanoide et en intelligence artificielle physique.
      Cette veille s'inscrit dans le cadre du BTS SIO (B1.6) et reflete ma curiosite
      pour les nouvelles technologies et leur integration dans le monde industriel.
    </p>
  </section>

  <section class="space-y-4">
    {[...articles].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).map((article) => (
      <a
        href={`/veille/${article.slug}`}
        class="group block rounded-lg border border-border bg-card p-5 transition-colors hover:bg-accent"
      >
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center rounded border border-border px-1.5 py-0.5 font-mono text-[10px] text-muted-foreground">
                {article.tag}
              </span>
              <span class="font-mono text-xs text-muted-foreground">
                {formatDate(article.date)}
              </span>
            </div>
            <h2 class="mt-2 font-medium leading-snug group-hover:text-foreground">
              {article.title}
            </h2>
            <p class="mt-1 font-mono text-[10px] text-muted-foreground">{article.bornage}</p>
            <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">
              {article.summary}
            </p>
            <p class="mt-2 font-mono text-[10px] text-muted-foreground">
              Source : {article.sourceLabel}
            </p>
          </div>
          <svg
            class="mt-1 h-4 w-4 flex-shrink-0 text-muted-foreground transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M9 5l7 7-7 7" />
          </svg>
        </div>
      </a>
    ))}
  </section>
</Layout>
